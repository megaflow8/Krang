# -evdev: Used both in console and X/Wayland
# ssl: Mandatory for secure web traffic, fetching packages, and encrypted communication.
USE=${USE} -wxwidgets -sdl -sdl2 -evdev ssl alsa nvme apparmor bluetooth lvm bash-completion lm-sensors hddtemp verify-sig cryptsetup

# sys-kernel/gentoo-kernel requirement
# The Linux kernel cannot natively decrypt a LUKS container or scan for LVM
# logical volumes on its own. It requires the early user-space environment
# provided by an initramfs, which contains the necessary cryptsetup and lvm
# binaries to unlock and mount your root partition before the main init system
# starts.
sys-kernel/installkernel dracut

# Disable legacy translation databases for modern IPP printers
net-print/cups-meta -foomatic
net-print/cups-filters -foomatic

# Prune massive redundant typography packages from the install plan
# I do not need 14 different font families for a clean desktop layout. GNOME
# natively relies on media-fonts/cantarell for its system shell, and the
# terminal code layouts will look crisp using media-fonts/source-code-pro or
# dejavu.
media-fonts/fonts-meta -latin

# Compiles a headless, low-overhead version of the some tools
app-text/mupdf -X
sys-apps/lshw -gtk
media-gfx/fontforge -gtk -X
app-office/libreoffice pdfimport -mariadb -branding
sys-libs/ncurses -gpm
www-client/chromium -system-png widevine # -system-png because firefox adds "apng" to libpng
